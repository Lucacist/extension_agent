{
  "manifest_version": 3,
  "name": "AdBlocker",
  "version": "5.39.12",
  "description": "Extension sans égal contre la publicité et les pop-ups. Bloque les publicités sur Facebook, YouTube et tous les autres sites web.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "alarms" 
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ],
  "commands": {
    "explain-text": {
      "suggested_key": {
        "default": "Ctrl+Shift+X",
        "mac": "Command+Shift+X"
      },
      "description": "Expliquer le texte surligné"
    },
    "capture-zone": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Capturer une zone et analyser"
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/frame.png",
      "48": "icons/frame.png",
      "128": "icons/frame.png"
    }
  },
  "icons": {
    "16": "icons/frame.png",
    "48": "icons/frame.png",
    "128": "icons/frame.png"
  }
}
